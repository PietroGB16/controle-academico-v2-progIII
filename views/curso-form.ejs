<%- include('partials/header') %>

<h1><%= curso ? 'Editar curso' : 'Novo curso' %></h1>

<form action="<%= curso ? '/cursos/' + curso.id : '/cursos' %>" method="POST" class="form-cadastro">
  <label for="nome">Nome do curso</label>
  <input type="text" id="nome" name="nome" required value="<%= curso ? curso.nome : '' %>" />

  <label for="cargaHoraria">Carga horária (horas)</label>
  <input type="number" id="cargaHoraria" name="cargaHoraria" required min="0" value="<%= curso ? curso.cargaHoraria : '' %>" />

  <label for="coordenador">Coordenador(a)</label>
  <input type="text" id="coordenador" name="coordenador" required value="<%= curso ? curso.coordenador : '' %>" />

  <div class="acoes-form">
    <input type="submit" value="<%= curso ? 'Salvar alterações' : 'Cadastrar' %>" class="btn" />
    <a href="/cursos" class="btn btn-secundario">Cancelar</a>
  </div>
</form>

<%- include('partials/footer') %>
