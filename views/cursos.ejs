<%- include('partials/header') %>

<div class="topo-pagina">
  <h1>Cursos</h1>
  <a href="/cursos/novo" class="btn">+ Novo curso</a>
</div>

<form action="/cursos" method="GET" class="form-busca">
  <input type="text" name="busca" placeholder="Buscar curso pelo nome..." value="<%= busca %>" />
  <input type="submit" value="Buscar" />
  <% if (busca) { %>
    <a href="/cursos" class="link-limpar">limpar</a>
  <% } %>
</form>

<% if (typeof erro !== 'undefined' && erro) { %>
  <p class="aviso aviso-erro"><%= erro %></p>
<% } %>

<% if (cursos.length === 0) { %>
  <p class="aviso">Nenhum curso encontrado<% if (busca) { %> para "<%= busca %>"<% } %>.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Carga horária</th>
        <th>Coordenador(a)</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% cursos.forEach(function(curso) { %>
        <tr>
          <td><%= curso.nome %></td>
          <td><%= curso.cargaHoraria %>h</td>
          <td><%= curso.coordenador %></td>
          <td class="acoes">
            <a href="/cursos/<%= curso.id %>/editar">Editar</a>
            <form action="/cursos/<%= curso.id %>/excluir" method="POST" onsubmit="return confirm('Excluir este curso?');">
              <input type="submit" value="Excluir" class="btn-excluir" />
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>
