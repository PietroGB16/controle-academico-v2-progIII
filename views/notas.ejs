<%- include('partials/header') %>

<h1>Minhas Notas</h1>
<p>
  Essa tabela é armazenada no <code>localStorage</code> do navegador — os dados
  ficam salvos mesmo se você recarregar a página, mas só existem no seu computador.
</p>

<form id="form-nota" class="form-cadastro form-notas">
  <input type="hidden" id="nota-id" value="" />

  <label for="disciplina">Disciplina</label>
  <input type="text" id="disciplina" required placeholder="Ex: Programação III" />

  <label for="av1">AV1 (0 a 10)</label>
  <input type="number" id="av1" min="0" max="10" step="0.1" required />

  <label for="av2">AV2 (0 a 10)</label>
  <input type="number" id="av2" min="0" max="10" step="0.1" required />

  <div class="acoes-form">
    <input type="submit" id="btn-salvar-nota" value="Adicionar" class="btn" />
    <button type="button" id="btn-cancelar-nota" class="btn btn-secundario oculto">Cancelar edição</button>
  </div>
</form>

<div class="form-busca">
  <input type="text" id="filtro-notas" placeholder="Filtrar por disciplina..." />
</div>

<table id="tabela-notas">
  <thead>
    <tr>
      <th>Disciplina</th>
      <th>AV1</th>
      <th>AV2</th>
      <th>Média</th>
      <th>Situação</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody id="corpo-tabela-notas">
    <!-- preenchido via JavaScript a partir do localStorage -->
  </tbody>
</table>

<p id="mensagem-vazia" class="aviso oculto">Nenhuma disciplina cadastrada ainda.</p>

<script src="/js/notas.js"></script>

<%- include('partials/footer') %>
